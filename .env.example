# Korea Investment & Securities Open API
# Keep real secrets in .env. Do not commit .env.
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=

# Production server:
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# Paper trading server:
# KIS_BASE_URL=https://openapivts.koreainvestment.com:29443

# Optional. Used later for account endpoints, not needed for daily price history.
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_PAPER_ACCOUNT_NO=
KIS_PAPER_ACCOUNT_PRODUCT_CODE=01

# true or false. Used to choose default transaction IDs when applicable.
KIS_IS_PAPER=false
